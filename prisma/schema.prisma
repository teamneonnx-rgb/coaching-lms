// Multi-Tenant Coaching Institute LMS — Prisma Schema
// Target per PRD §5 / SRD §3. Hierarchy: Batch → Course → Chapter → Resource (FR-COURSE-01)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  IT
  TEACHER
  STUDENT
  PARENT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum ResourceType {
  VIDEO
  PDF
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  ON_LEAVE
}

enum NotificationType {
  TEACHER_ATTENDANCE
  STUDENT_ENROLLMENT
  SYSTEM_ALERT
}

enum AssessmentType {
  OBJECTIVE
  SUBJECTIVE
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
}

// Content publishing approval (FR-APR). Teacher-added resources start PENDING
// and are hidden from students until an admin approves them. Existing rows and
// admin-added content default to APPROVED so behaviour is unchanged on upgrade.
enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  phone         String? // FR-AU-01 — phone login identifier
  password      String // bcryptjs hash, salt rounds >= 10 (FR-AUTH-03)
  role          Role
  status        UserStatus     @default(ACTIVE) // FR-AUTH-9
  // Auth hardening (FR-AU-02/05)
  mustChangePassword  Boolean   @default(false) // forced change on first login for admin-created accounts
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  createdById         String?
  parentName    String?
  parentPhone   String?
  parentEmail   String?
  // Multi-tenancy (Q1) — every user belongs to one institute.
  instituteId   String?
  institute     Institute?     @relation(fields: [instituteId], references: [id])
  attendances       Attendance[]
  notifications     Notification[]
  courses           Course[] // For Teachers
  enrollments       Enrollment[] // For Students
  progress          ResourceProgress[] // For Students
  assessments       Assessment[]       @relation("TeacherAssessments") // For Teachers
  submissions       Submission[]       @relation("StudentSubmissions") // For Students
  gradedSubmissions Submission[]       @relation("GradedSubmissions") // For Teachers
  assignments       Assignment[]       @relation("TeacherAssignments") // For Teachers
  assignmentSubmissions AssignmentSubmission[] @relation("StudentAssignmentSubmissions") // For Students
  gradedAssignments AssignmentSubmission[] @relation("GradedAssignmentSubmissions") // For Teachers
  // Q&A / discussion (FR-QNA, FR-CMT, FR-FBK)
  doubts            Doubt[]            @relation("DoubtAuthor")
  doubtReplies      DoubtReply[]       @relation("DoubtReplyAuthor")
  comments          Comment[]          @relation("CommentAuthor")
  feedback          Feedback[]         @relation("FeedbackAuthor")
  // Capability delegation (FR-SA-03, FR-PM-01/02)
  capabilities      AdminCapability[]  @relation("AdminCapabilities")
  grantedCapabilities AdminCapability[] @relation("GrantedCapabilities")
  // Parent ↔ student links (FR-PAR-1)
  childLinks        ParentLink[]       @relation("ParentOf") // rows where this user is the parent
  parentLinks       ParentLink[]       @relation("StudentOf") // rows where this user is the student
  auditEntries      AuditEntry[]       // actions this user performed
  // Soft delete (FR-DATA-1/2)
  deletedAt         DateTime?
  deletedById       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([instituteId])
}

// FR-1.2 / Q1 — a tenant. All data hangs off exactly one institute.
model Institute {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  timezone  String   @default("Asia/Kolkata")
  currency  String   @default("INR")
  isActive  Boolean  @default(true)
  users     User[]
  batches   Batch[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Links a parent account to a student account (FR-PAR-1).
model ParentLink {
  id        String   @id @default(cuid())
  parentId  String
  parent    User     @relation("ParentOf", fields: [parentId], references: [id], onDelete: Cascade)
  studentId String
  student   User     @relation("StudentOf", fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([parentId, studentId])
  @@index([studentId])
}

// Per-institute key/value settings — integration credentials + feature toggles,
// editable from the Control Center (FR-CC-1, FR-SMTP-1, FR-PAY-2, FR-WA-1).
// Secret values are masked in the UI and never returned to the client.
model Setting {
  id          String   @id @default(cuid())
  instituteId String
  key         String // e.g. "razorpay.keyId", "whatsapp.token", "feature.approval"
  value       String
  updatedAt   DateTime @updatedAt

  @@unique([instituteId, key])
  @@index([instituteId])
}

// Immutable audit trail of privileged/destructive actions (FR-AT-01/02).
model AuditEntry {
  id          String   @id @default(cuid())
  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id])
  actorRole   String?
  action      String // e.g. "user.delete", "capability.grant"
  entity      String // e.g. "User"
  entityId    String?
  detail      String? // human-readable summary
  beforeValue String? // JSON snapshot before the change (FR-AT-01)
  afterValue  String? // JSON snapshot after the change
  ip          String?
  createdAt   DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

// One row per capability granted to an ADMIN (FR-SA-03). Absence = denied.
// SUPER_ADMIN never consults this table (short-circuit, FR-SA-01); roles other
// than ADMIN can never hold a row that matters. Looked up per request — never
// cached in the JWT — so revocation is immediate (FR-SA-04).
model AdminCapability {
  id            String   @id @default(cuid())
  adminUserId   String
  admin         User     @relation("AdminCapabilities", fields: [adminUserId], references: [id], onDelete: Cascade)
  capabilityKey String // e.g. "PAYMENT_COLLECT" — whitelisted in src/lib/capabilities.ts
  grantedById   String?
  grantedBy     User?    @relation("GrantedCapabilities", fields: [grantedById], references: [id])
  grantedAt     DateTime @default(now())

  @@unique([adminUserId, capabilityKey])
  @@index([adminUserId])
}

model Batch {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  startDate   DateTime     @default(now())
  endDate     DateTime?
  isActive    Boolean      @default(true)
  instituteId String?
  institute   Institute?   @relation(fields: [instituteId], references: [id])
  courses     Course[]
  enrollments Enrollment[]
  attendances Attendance[]
  deletedAt   DateTime?
  deletedById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([instituteId])
}

// Students are grouped into Batches (PRD Module B). isActive marks the
// student's current batch — content isolation keys off it (FR-COURSE-02).
model Enrollment {
  id         String   @id @default(cuid())
  studentId  String
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  batchId    String
  batch      Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  isActive   Boolean  @default(true)
  enrolledAt DateTime @default(now())

  @@unique([studentId, batchId])
  @@index([batchId])
}

model Course {
  id          String    @id @default(cuid())
  title       String
  description String?
  batchId     String
  batch       Batch        @relation(fields: [batchId], references: [id], onDelete: Cascade)
  teacherId   String
  teacher     User         @relation(fields: [teacherId], references: [id])
  chapters    Chapter[]
  assessments Assessment[]
  assignments Assignment[]
  doubts      Doubt[]
  feedback    Feedback[]
  deletedAt   DateTime?
  deletedById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([batchId])
  @@index([teacherId])
}

model Chapter {
  id        String     @id @default(cuid())
  title     String
  order     Int        @default(0)
  courseId  String
  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  resources Resource[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([courseId])
}

model Resource {
  id        String       @id @default(cuid())
  title     String
  type      ResourceType
  fileKey   String // S3/R2 object key — served via signed URLs, expiry <= 3600s (FR-COURSE-03)
  fileSize  Int? // bytes
  duration  Int? // seconds, VIDEO only
  order     Int          @default(0)
  chapterId String
  chapter   Chapter      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  progress  ResourceProgress[]
  comments  Comment[]
  // Approval workflow (FR-APR)
  approvalStatus ApprovalStatus @default(APPROVED)
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([chapterId])
  @@index([approvalStatus])
}

// Per-student completion tracking (powers the "Process vs Done" progress donut).
model ResourceProgress {
  id          String   @id @default(cuid())
  studentId   String
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  resourceId  String
  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@unique([studentId, resourceId])
  @@index([studentId])
}

model Attendance {
  id       String           @id @default(cuid())
  date     DateTime         @default(now()) @db.Date
  status   AttendanceStatus @default(PRESENT)
  userId   String
  user     User             @relation(fields: [userId], references: [id])
  batchId  String?
  batch    Batch?           @relation(fields: [batchId], references: [id])
  markedAt DateTime         @default(now())
  // Validation workflow (FR-ATT-4/5): student self-marks stay pending until a
  // teacher validates. validatedById = the validating teacher; null = pending.
  validatedById String?
  validatedAt   DateTime?

  // FR-ATT-01: prevents duplicate attendance entries
  @@unique([userId, date, batchId])
  @@index([batchId, date])
}

model Notification {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      NotificationType @default(SYSTEM_ALERT)
  isRead    Boolean          @default(false)
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
}

// ── Assessments (Phase 7) ──────────────────────────────────────────
// An assessment belongs to a Course (→ Batch), so student access inherits
// batch isolation (FR-COURSE-02). OBJECTIVE = auto-graded MCQs with negative
// marking; SUBJECTIVE = student uploads a PDF/image scan for manual grading.
model Assessment {
  id              String         @id @default(cuid())
  title           String
  description     String?
  type            AssessmentType @default(OBJECTIVE)
  courseId        String
  course          Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacherId       String
  teacher         User           @relation("TeacherAssessments", fields: [teacherId], references: [id])
  negativeMarking Float          @default(0) // fraction of points deducted per wrong answer (0..1)
  timeLimit       Int? // minutes
  isPublished     Boolean        @default(false)
  questions       Question[]
  submissions     Submission[]
  deletedAt       DateTime?
  deletedById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([courseId])
  @@index([teacherId])
}

model Question {
  id           String           @id @default(cuid())
  assessmentId String
  assessment   Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  text         String
  points       Int              @default(1)
  order        Int              @default(0)
  options      QuestionOption[]
  answers      Answer[]

  @@index([assessmentId])
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean  @default(false)
  order      Int      @default(0)
  answers    Answer[]

  @@index([questionId])
}

model Submission {
  id           String           @id @default(cuid())
  assessmentId String
  assessment   Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User             @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
  status       SubmissionStatus @default(SUBMITTED)
  score        Float?
  maxScore     Int?
  feedback     String?
  fileKey      String? // subjective upload (PDF/image), served via signed URL
  gradedById   String?
  gradedBy     User?            @relation("GradedSubmissions", fields: [gradedById], references: [id])
  gradedAt     DateTime?
  submittedAt  DateTime         @default(now())
  answers      Answer[]

  @@unique([assessmentId, studentId])
  @@index([assessmentId])
  @@index([studentId])
}

model Answer {
  id               String          @id @default(cuid())
  submissionId     String
  submission       Submission      @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId       String
  question         Question        @relation(fields: [questionId], references: [id])
  selectedOptionId String?
  selectedOption   QuestionOption? @relation(fields: [selectedOptionId], references: [id])
  isCorrect        Boolean?

  @@index([submissionId])
}

// ── Assignments (Phase / FR-ASG) ───────────────────────────────────
enum AssignmentSubmissionType {
  FILE
  TEXT
  BOTH
}

model Assignment {
  id             String                   @id @default(cuid())
  title          String
  instructions   String?
  courseId       String
  course         Course                   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacherId      String
  teacher        User                     @relation("TeacherAssignments", fields: [teacherId], references: [id])
  dueDate        DateTime?
  totalMarks     Int                      @default(100)
  allowLate      Boolean                  @default(true)
  submissionType AssignmentSubmissionType @default(BOTH)
  submissions    AssignmentSubmission[]
  deletedAt      DateTime?
  deletedById    String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([courseId])
  @@index([teacherId])
}

model AssignmentSubmission {
  id           String           @id @default(cuid())
  assignmentId String
  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User             @relation("StudentAssignmentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
  text         String?
  fileKey      String? // uploaded file, served via signed URL
  status       SubmissionStatus @default(SUBMITTED)
  score        Float?
  feedback     String?
  isLate       Boolean          @default(false)
  gradedById   String?
  gradedBy     User?            @relation("GradedAssignmentSubmissions", fields: [gradedById], references: [id])
  gradedAt     DateTime?
  submittedAt  DateTime         @default(now())

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
}

// ── Q&A / Comments / Feedback (FR-QNA, FR-CMT, FR-FBK) ──────────────
// A "doubt" is a course-scoped question thread. Access inherits batch
// isolation through Course → Batch. Teachers of the course + students in
// the batch can view; teachers can mark resolved / accept a reply.
model Doubt {
  id          String       @id @default(cuid())
  title       String
  body        String
  courseId    String
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  authorId    String
  author      User         @relation("DoubtAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  isResolved  Boolean      @default(false)
  replies     DoubtReply[]
  deletedAt   DateTime?
  deletedById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([courseId])
  @@index([authorId])
}

model DoubtReply {
  id         String    @id @default(cuid())
  doubtId    String
  doubt      Doubt     @relation(fields: [doubtId], references: [id], onDelete: Cascade)
  authorId   String
  author     User      @relation("DoubtReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body       String
  isAccepted Boolean   @default(false)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([doubtId])
}

// Threaded comments on a content Resource (FR-CMT). Author may be a
// student (in the batch) or the course teacher.
model Comment {
  id         String    @id @default(cuid())
  resourceId String
  resource   Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  authorId   String
  author     User      @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  body       String
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([resourceId])
}

// One rating (1–5) + optional review per student per course (FR-FBK).
model Feedback {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  studentId String
  student   User     @relation("FeedbackAuthor", fields: [studentId], references: [id], onDelete: Cascade)
  rating    Int // 1..5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseId, studentId])
  @@index([courseId])
}
