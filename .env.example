# ── Database (Phase 1) ─────────────────────────────────────────────
# PostgreSQL 15+ hosted on Supabase or Neon.
# DATABASE_URL = transaction pooler (port 6543, pgbouncer=true) for app runtime.
# DIRECT_URL   = session pooler (port 5432) for Prisma migrations.
# Supabase: copy both from Dashboard → Connect → ORMs/Prisma.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# ── Authentication — NextAuth.js v5 (Phase 2) ──────────────────────
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""
# Optional in dev (trustHost infers the host). In production set to the
# deployed origin, e.g. https://lms.yourdomain.com
# AUTH_URL="http://localhost:3000"

# ── Storage — AWS S3 / Cloudflare R2 (Phase 4) ─────────────────────
S3_REGION="ap-south-1"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Required for Cloudflare R2 only, e.g. https://<account-id>.r2.cloudflarestorage.com
S3_ENDPOINT=""

# ── Notifications (Phase 5) ────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="LMS <noreply@example.com>"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ── Queue / Worker — Upstash QStash (Phase 5) ──────────────────────
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""
# Public base URL QStash calls back into (deployed URL in production)
APP_URL="http://localhost:3000"
